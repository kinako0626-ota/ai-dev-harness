{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd {{PROJECT_DIR}} && {{ANALYZE_CMD}} 2>&1",
            "timeout": 120000
          }
        ]
      }
    ]
  }
}
